# An initially created superuser.
SUPERUSER_USERNAME="medreporter"
SUPERUSER_EMAIL="medreporter@medreporter.org"
SUPERUSER_PASSWORD="medreporter"

# The database connection string.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Secret for Better-Auth.
